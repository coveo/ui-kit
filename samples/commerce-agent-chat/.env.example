# "local" → proxies through Vite to localhost:8080 (Agent Smith)
# "coveo-dev" → proxies through Vite to the Coveo dev platform
VITE_AGENT_MODE=local
VITE_AGENT_URL=/api
VITE_ORG_ID=your_org_id_here
VITE_ACCESS_TOKEN=your_access_token_here
VITE_PLATFORM_URL=https://platformdev.cloud.coveo.com
VITE_TRACKING_ID=your_tracking_id_here
VITE_LANGUAGE=en
VITE_COUNTRY=US
VITE_CURRENCY=USD
VITE_TIMEZONE=America/Montreal
VITE_CLIENT_ID=your_client_id_here
VITE_CONTEXT_URL=https://example.com
