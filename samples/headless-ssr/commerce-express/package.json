{
  "name": "@coveo/ui-kit-sample-headless-ssr-commerce-express",
  "version": "0.1.0",
  "private": true,
  "description": "Commerce server-side rendering (SSR) with @coveo/headless/ssr-commerce and an Express server",
  "type": "module",
  "scripts": {
    "dev": "pnpm build:client --watch=forever & pnpm build:server --watch & node --watch ./dist/server.js",
    "build": "pnpm build:server && pnpm build:client && pnpm build:mocks",
    "build:server": "tsc -p tsconfig.build.json",
    "build:client": "esbuild ./src/client.ts --bundle --outfile=dist/client.js --format=esm --target=es2022",
    "build:mocks": "esbuild ./mocks/register.ts --bundle --outfile=dist-mocks/register.mjs --format=esm --platform=node",
    "start": "node ./dist/server.js",
    "e2e": "playwright test",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@coveo/headless": "workspace:*",
    "express": "5.2.1"
  },
  "devDependencies": {
    "@coveo/platform-mock-api": "workspace:*",
    "@msw/playwright": "catalog:",
    "@playwright/test": "catalog:",
    "@types/express": "5.0.6",
    "@types/node": "catalog:",
    "esbuild": "catalog:",
    "msw": "catalog:",
    "typescript": "catalog:"
  }
}
