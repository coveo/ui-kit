node('linux && docker') {
  def commitHash = params.commitHash

  checkout([
    $class: 'GitSCM',
    branches: [[name: commitHash]],
    extensions: [],
    userRemoteConfigs: [[credentialsId: 'github-app-coveo-platform', url: 'https://github.com/coveo-platform/relay']]
  ])

  withDockerContainer(image: 'node:20', args: '-u=root -e HOME=/tmp -e NPM_CONFIG_PREFIX=/tmp/.npm') {
    stage('Npm login') {
      withCredentials([string(credentialsId: 'NPM_TOKEN', variable: 'NPM_TOKEN')]) {
        sh 'npm run npm:login:ci'
      }
    }

    stage('Setup pnpm') {
      sh 'corepack enable'
      sh 'corepack prepare --activate'
    }

    stage('Npm tag') {
      sh 'npm run npm:tag:latest'
    }

    stage('Notify docs') {
      withCredentials([
        usernamePassword(credentialsId: 'github-commit-token', usernameVariable: 'GITHUB_USERNAME', passwordVariable: 'GITHUB_TOKEN')
      ]) {
        sh 'pnpm i @octokit/rest --filter @coveo/relay'
        sh 'npm run docs:notify'
      }
    }
  }
}
