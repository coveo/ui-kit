{
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "pnpm -r lint && npm run prettier -- --check",
    "lint:fix": "pnpm -r lint:fix && npm run prettier -- --write",
    "prettier": "prettier \"**/*.{js,mjs,ts,tsx,json,md,yml}\"",
    "test": "turbo run test",
    "version-bump": "node ./scripts/version-bump.mjs",
    "npm:publish:alpha": "pnpm -r publish --tag alpha",
    "npm:tag:beta": "pnpm -r run npm:tag beta",
    "npm:tag:latest": "pnpm -r run npm:tag latest",
    "docs:notify": "node ./packages/relay/scripts/notify-docs.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@actions/github": "^6.0.0",
    "@coveo/semantic-monorepo-tools": "^2.1.9",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "conventional-changelog-angular": "^8.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.0.0",
    "ts-dedent": "^2.2.0",
    "turbo": "latest"
  },
  "name": "relay",
  "packageManager": "pnpm@10.27.0"
}
