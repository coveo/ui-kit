{
  "name": "ui-kit",
  "version": "3.0.98",
  "private": true,
  "scripts": {
    "postinstall": "husky install",
    "reset:install": "git checkout origin/main pnpm-lock.yaml && pnpm install",
    "clean:install": "git clean -xfd && pnpm run reset:install",
    "dev:atomic": "concurrently \"pnpm --filter @coveo/headless dev\" \"pnpm --filter @coveo/atomic start\"",
    "build": "turbo build",
    "test": "turbo test",
    "e2e": "turbo e2e",
    "lint:check": "oxlint --deny-warnings . && oxfmt --check . && turbo lint:check --filter=@coveo/quantic && cspell **/*.md --no-progress --show-suggestions --show-context",
    "lint:fix": "oxlint --deny-warnings --fix . && oxfmt . && turbo lint:fix --filter=@coveo/quantic && cspell **/*.md --no-progress --show-suggestions --show-context",
    "package-compatibility": "node ./scripts/ci/package-compatibility.mjs",
    "pr:report": "echo 'TODO KIT-5109: pr:report must be reactivated after pnpm has been merged in main'",
    "report:bundle-size:time-series": "node ./scripts/reports/bundle-size/time-series.mjs",
    "pre-commit": "lint-staged",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish:npm:latest": "turbo npm:publish --concurrency=1",
    "notify:docs": "node ./scripts/notify-docs/published-ui-kit.mjs",
    "release": "pnpm run nx:graph && pnpm run release:phase0 && pnpm run release:phase1 && pnpm run release:phase2 && pnpm run release:phase3",
    "nx:graph": "turbo release:phase1 --dry-run=json > topology-raw.json && node scripts/transform-topology.mjs topology-raw.json topology.json",
    "release:phase0": "pnpm --filter @coveo/ci git-lock",
    "release:phase1": "turbo release:phase1 --concurrency=1 && pnpm run build",
    "release:phase2": "pnpm --filter @coveo/ci bump:root",
    "release:phase3": "pnpm --filter @coveo/ci git-publish-all",
    "knip": "knip"
  },
  "devDependencies": {
    "@actions/core": "3.0.0",
    "@actions/github": "9.0.0",
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.30.0",
    "@coveo/ci": "workspace:*",
    "@cspell/dict-fr-fr": "2.3.2",
    "@playwright/mcp": "catalog:",
    "@tsconfig/node22": "22.0.0",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "concurrently": "9.2.1",
    "cspell": "9.4.0",
    "esbuild": "catalog:",
    "esbuild-plugin-alias": "0.2.1",
    "esbuild-plugin-umd-wrapper": "3.0.0",
    "husky": "9.1.7",
    "knip": "5.88.0",
    "lint-staged": "16.2.7",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "playwright": "catalog:",
    "publint": "0.3.18",
    "turbo": "2.8.15",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "overrides": {
    "@coveo/ci": {
      "@types/async-retry": {
        "@types/retry": "0.12.5"
      }
    }
  },
  "engines": {
    "node": "^22.14.0 || ^24.11.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.26.2",
  "pnpm": {
    "patchedDependencies": {
      "@stencil/core@4.20.0": "patches/@stencil+core+4.20.0.patch",
      "@wc-toolkit/storybook-helpers@10.0.0": "patches/@wc-toolkit+storybook-helpers+10.0.0.patch",
      "jest-environment-jsdom@29.7.0": "patches/jest-environment-jsdom+29.7.0.patch"
    },
    "overrides": {
      "braces": "3.0.3",
      "react": "catalog:",
      "react-dom": "catalog:",
      "typescript": "catalog:",
      "html-minifier": "npm:html-minifier-terser@^7.2.0",
      "@angular/core": "catalog:",
      "@angular/common": "catalog:"
    }
  }
}
