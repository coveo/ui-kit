{
  "product": "relay",
  "team_name": "dataplatformfoundation",
  "general": {
    "environments_order": {
      "sequential": ["dev", "stg", "prd"]
    },
    "notifications": {
      "slack_channels": ["analyticsdeployments"]
    },
    "team_jenkins": "uabuilds",
    "start_environment_automatically": true,
    "prd": {
      "start_environment_automatically": false
    }
  },
  "ordered_phases": [
    {
      "id": "deploy-relay-major-to-s3-version",
      "s3": {
        "bucket": "{terraform.infra.infra.bucket_binaries}",
        "directory": "proda/StaticCDN/relay/v$[RELAY_MAJOR_VERSION]",
        "source": "packages/relay/lib/cdn",
        "parameters": {
          "acl": "public-read"
        }
      }
    },
    {
      "id": "playground",
      "s3": {
        "bucket": "{terraform.infra.infra.bucket_binaries}",
        "directory": "proda/StaticCDN/relay/playground/",
        "source": "apps/playground/out/",
        "parameters": {
          "acl": "public-read"
        }
      }
    },
    {
      "id": "stg-release",
      "team_jenkins": {
        "disabled": true,
        "job_name": "relay-stg-release",
        "extra_parameters": {
          "commitHash": "$[COMMIT_HASH]"
        },
        "stg": {
          "disabled": false
        }
      }
    },
    {
      "id": "prd-release",
      "team_jenkins": {
        "disabled": true,
        "job_name": "relay-prd-release",
        "extra_parameters": {
          "commitHash": "$[COMMIT_HASH]"
        },
        "prd": {
          "disabled": false
        }
      }
    }
  ],
  "certifiers": {},
  "observatory": {
    "no_endpoint": true
  },
  "package_rollout": {
    "only_consider_changesets_after": "90d72154b507b5e28e104f922be29efca7708ebc"
  },
  "deployment_config_version": 13
}
