{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "runtimeVersion": "24",
      "request": "launch",
      "name": "Vitest All",
      "program": "${workspaceFolder}/packages/relay/node_modules/vitest/vitest.mjs",
      "args": ["run", "--config", "vitest.config.js"],
      "cwd": "${workspaceFolder}/packages/relay",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "windows": {
        "program": "${workspaceFolder}/packages/relay/node_modules/vitest/vitest.mjs"
      }
    },
    {
      "type": "node",
      "runtimeVersion": "24",
      "request": "launch",
      "name": "Vitest Current File",
      "program": "${workspaceFolder}/packages/relay/node_modules/vitest/vitest.mjs",
      "args": [
        "run",
        "${fileBasenameNoExtension}",
        "--config",
        "vitest.config.js"
      ],
      "cwd": "${workspaceFolder}/packages/relay",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "windows": {
        "program": "${workspaceFolder}/packages/relay/node_modules/vitest/vitest.mjs"
      }
    }
  ]
}
