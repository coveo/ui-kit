{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "share": "manual",
  "instructions": [
    ".github/instructions/general.instructions.md",
    ".github/instructions/general.typescript.instructions.md"
  ],
  "formatter": {
    "oxfmt": {
      "command": ["pnpm", "exec", "oxfmt", "$FILE"],
      "extensions": [
        ".js",
        ".ts",
        ".jsx",
        ".tsx",
        ".json",
        ".jsonc",
        ".css",
        ".html",
        ".md"
      ]
    }
  },
  "mcp": {
    "atlassian": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.atlassian.com/v1/sse"
      ],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp"],
      "enabled": true
    },
    "context7": {
      "enabled": false
    }
  },
  "permission": {
    "bash": {
      "*": "ask",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git status *": "allow"
    },
    "webfetch": "ask"
  },
  "compaction": {
    "auto": true,
    "prune": true
  }
}
