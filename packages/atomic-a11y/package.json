{
  "private": true,
  "version": "1.0.0",
  "name": "@coveo/atomic-a11y",
  "description": "Accessibility utilities and tools for Coveo Atomic components",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "generate:wcag": "node scripts/generate-wcag-criteria.mjs",
    "build": "pnpm generate:wcag && tsc -p tsconfig.json",
    "a11y:vpat": "pnpm build && node scripts/json-to-openacr.mjs && npx --yes @openacr/openacr output -f reports/openacr.yaml -o reports/vpat-2.5-coveo-atomic.md -t scripts/vpat-from-openacr.handlebars",
    "a11y:merge-shards": "pnpm build && node scripts/merge-shards-cli.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "axe-core": "4.10.3",
    "openai": "6.22.0",
    "playwright": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "openai": ">=4.0.0",
    "playwright": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    },
    "playwright": {
      "optional": true
    }
  }
}
