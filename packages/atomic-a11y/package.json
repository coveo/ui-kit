{
  "name": "@coveo/atomic-a11y",
  "version": "1.0.0",
  "private": true,
  "description": "Accessibility utilities and tools for Coveo Atomic components",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "a11y:merge-shards": "node scripts/merge-shards-cli.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "a11y:validate": "node scripts/validate-openacr.mjs",
    "a11y:vpat": "node scripts/json-to-openacr.mjs && node scripts/validate-openacr.mjs && node scripts/generate-vpat.mjs",
    "a11y:vpat-pdf": "node scripts/build-vpat-pdf.mjs",
    "a11y:update-openacr": "node scripts/update-openacr.mjs"
  },
  "dependencies": {
    "handlebars": "4.7.9",
    "marked": "12.0.2",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "ajv": "8.20.0",
    "axe-core": "4.11.4",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
