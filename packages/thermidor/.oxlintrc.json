{
  "extends": ["../../.oxlintrc.json"],
  "overrides": [
    {
      "files": ["src/index.ts", "src/public/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": [
                  "@ag-ui/core",
                  "@ag-ui/core/*",
                  "@reduxjs/toolkit",
                  "@reduxjs/toolkit/*",
                  "immer",
                  "redux-thunk",
                  "reselect"
                ],
                "message": "Public surface must not depend on Redux, Immer, AG-UI, or related ecosystem packages directly."
              },
              {
                "group": [
                  "@/src/internal/features/*/*",
                  "!@/src/internal/features/*/index.js",
                  "@/src/internal/api/*/*",
                  "!@/src/internal/api/*/index.js",
                  "@/src/internal/engine/*",
                  "!@/src/internal/engine/index.js",
                  "@/src/internal/utils/*",
                  "!@/src/internal/utils/index.js"
                ],
                "message": "Import from the barrel (index.ts), not deep paths. Use @/src/internal/features/<name> or @/src/internal/api/<name>."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/internal/**"],
      "excludeFiles": ["**/*.test.ts", "**/*.test-d.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@/src/public/**"],
                "message": "Internal modules must not import from the public surface. Move the shared code into src/internal/."
              }
            ]
          }
        ]
      }
    }
  ]
}
