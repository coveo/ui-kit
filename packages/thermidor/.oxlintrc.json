{
  "extends": ["../../.oxlintrc.json"],
  "overrides": [
    {
      "files": ["src/public/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": [
                  "@reduxjs/toolkit",
                  "@reduxjs/toolkit/*",
                  "immer",
                  "redux-thunk",
                  "reselect"
                ],
                "message": "Public layer must not depend on Redux, Immer, or related ecosystem packages directly."
              },
              {
                "group": [
                  "@/src/internal/features/*/*",
                  "!@/src/internal/features/*/index.js",
                  "@/src/internal/api/*/*",
                  "!@/src/internal/api/*/index.js",
                  "@/src/internal/engine/*",
                  "!@/src/internal/engine/index.js",
                  "@/src/internal/utils/*",
                  "!@/src/internal/utils/index.js"
                ],
                "message": "Import from the barrel (index.ts), not deep paths. Use @/src/internal/features/<name> or @/src/internal/api/<name>."
              }
            ]
          }
        ]
      }
    }
  ]
}
