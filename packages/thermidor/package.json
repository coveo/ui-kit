{
  "name": "@coveo/thermidor",
  "version": "0.1.0",
  "private": true,
  "description": "Unified framework-agnostic headless engine for search and conversational experiences",
  "homepage": "https://github.com/coveo/ui-kit",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coveo/ui-kit.git",
    "directory": "packages/thermidor"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./interfaces/commerce": {
      "types": "./dist/public/interfaces/commerce.d.ts",
      "import": "./dist/public/interfaces/commerce.js",
      "default": "./dist/public/interfaces/commerce.js"
    },
    "./interfaces/compose": {
      "types": "./dist/public/interfaces/compose.d.ts",
      "import": "./dist/public/interfaces/compose.js",
      "default": "./dist/public/interfaces/compose.js"
    },
    "./interfaces/generative": {
      "types": "./dist/public/interfaces/generative.d.ts",
      "import": "./dist/public/interfaces/generative.js",
      "default": "./dist/public/interfaces/generative.js"
    },
    "./interfaces/search": {
      "types": "./dist/public/interfaces/search.d.ts",
      "import": "./dist/public/interfaces/search.js",
      "default": "./dist/public/interfaces/search.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc --project ./tsconfig.build.json",
    "clean": "node ../../utils/ci/rm-rf.mjs dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ag-ui/core": "0.0.53",
    "@reduxjs/toolkit": "catalog:",
    "idb": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "^20.9.0 || ^22.11.0 || ^24.11.0"
  }
}
