{
  "name": "@coveo/relay",
  "version": "2.1.1",
  "description": "A library for sending analytics events using Coveo's Event protocol.",
  "keywords": [
    "Coveo",
    "Event Protocol",
    "analytics",
    "event"
  ],
  "homepage": "https://github.com/coveo/ui-kit/tree/main/packages/relay#readme",
  "bugs": {
    "url": "https://github.com/coveo/ui-kit/issues"
  },
  "license": "Apache-2.0",
  "author": "Coveo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coveo/ui-kit.git",
    "directory": "packages/relay"
  },
  "files": [
    "lib/npm/*",
    "lib/docs/*"
  ],
  "type": "module",
  "types": "./lib/npm/relay.d.ts",
  "exports": {
    "types": "./lib/npm/relay.d.ts",
    "browser": "./lib/npm/relay.mjs",
    "import": "./lib/npm/relay.mjs",
    "require": "./lib/npm/relay.cjs"
  },
  "scripts": {
    "build": "npm run clean && rollup --config ./config/rollup.config.mjs && npm run typedoc",
    "clean": "rimraf -rf ./lib",
    "test": "vitest run",
    "functional-test": "vitest run --config vitest.functional.config.ts",
    "test:watch": "vitest",
    "typedoc": "typedoc",
    "playwright:install": "pnpm exec playwright install --with-deps"
  },
  "dependencies": {
    "@coveo/explorer-messenger": "^0.5.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-replace": "^6.0.0",
    "@rollup/plugin-terser": "^0.4.3",
    "@rollup/plugin-typescript": "^12.0.0",
    "@vitest/browser-playwright": "^4.0.17",
    "jsdom": "^28.0.0",
    "playwright": "^1.57.0",
    "rimraf": "6.1.3",
    "rollup": "^4.0.0",
    "typedoc": "^0.28.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.17"
  }
}
