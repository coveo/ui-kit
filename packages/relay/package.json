{
  "name": "@coveo/relay",
  "version": "2.0.2",
  "description": "A library for sending analytics events using Coveo's Event protocol.",
  "type": "module",
  "files": [
    "lib/npm/*",
    "lib/docs/*"
  ],
  "types": "./lib/npm/relay.d.ts",
  "exports": {
    "types": "./lib/npm/relay.d.ts",
    "browser": "./lib/npm/relay.mjs",
    "import": "./lib/npm/relay.mjs",
    "require": "./lib/npm/relay.cjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coveo-platform/relay.git"
  },
  "keywords": [
    "Coveo",
    "analytics",
    "event",
    "Event Protocol"
  ],
  "author": "Coveo",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/coveo-platform/relay/issues"
  },
  "homepage": "https://github.com/coveo-platform/relay#readme",
  "scripts": {
    "build": "npm run clean && rollup --config ./config/rollup.config.mjs && npm run typedoc",
    "clean": "rimraf -rf ./lib",
    "lint": "eslint src/**",
    "lint:fix": "npm run lint -- --fix",
    "test": "vitest run",
    "functional-test": "vitest run --config vitest.functional.config.ts",
    "test:watch": "vitest",
    "npm:tag": "node ./scripts/update-npm-tag.mjs",
    "typedoc": "typedoc",
    "playwright:install": "pnpm exec playwright install --with-deps",
    "postinstall": "pnpm playwright:install"
  },
  "devDependencies": {
    "@octokit/rest": "^22.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-replace": "^6.0.0",
    "@rollup/plugin-terser": "^0.4.3",
    "@rollup/plugin-typescript": "^12.0.0",
    "@vitest/browser-playwright": "^4.0.17",
    "jsdom": "^28.0.0",
    "playwright": "^1.57.0",
    "rimraf": "6.1.2",
    "rollup": "^4.0.0",
    "tsconfig": "workspace:*",
    "typedoc": "^0.28.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.17",
    "globals": "17.3.0",
    "@eslint/js": "^10.0.0",
    "@eslint/eslintrc": "3.3.3"
  },
  "dependencies": {
    "@coveo/explorer-messenger": "^0.5.0",
    "uuid": "^13.0.0"
  }
}
