{
  "name": "@coveo/relay",
  "version": "0.7.6",
  "description": "A library for sending analytics events using Coveo's Event protocol.",
  "files": [
    "lib/**/*"
  ],
  "types": "./lib/types/relay.d.ts",
  "exports": {
    "node": {
      "import": {
        "types": "./lib/types/relay.d.ts",
        "default": "./lib/relay.mjs"
      },
      "require": {
        "types": "./lib/types/relay.d.ts",
        "default": "./lib/relay.cjs"
      }
    },
    "default": {
      "types": "./lib/types/relay.d.ts",
      "default": "./lib/relay.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coveo-platform/relay.git"
  },
  "keywords": [
    "Coveo",
    "analytics",
    "event",
    "Event Protocol"
  ],
  "author": "Coveo",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/coveo-platform/relay/issues"
  },
  "homepage": "https://github.com/coveo-platform/relay#readme",
  "scripts": {
    "build": "npm run clean && rollup --config ./config/rollup.config.mjs && npm run typedoc",
    "clean": "rimraf -rf ./lib",
    "lint": "eslint src/**",
    "lint:fix": "npm run lint -- --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "npm:tag": "node ./scripts/update-npm-tag.mjs",
    "typedoc": "typedoc"
  },
  "devDependencies": {
    "@octokit/rest": "^20.0.2",
    "@rollup/plugin-node-resolve": "^15.2.1",
    "@rollup/plugin-replace": "^5.0.2",
    "@rollup/plugin-terser": "^0.4.3",
    "@rollup/plugin-typescript": "^11.1.2",
    "@types/jest": "^29.5.3",
    "@types/node": "^17.0.12",
    "@types/uuid": "^9.0.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "rimraf": "5.0.5",
    "rollup": "^3.28.0",
    "ts-jest": "^29.1.1",
    "tsconfig": "workspace:*",
    "typedoc": "^0.25.3",
    "typescript": "^5.1.6"
  },
  "dependencies": {
    "@coveo/explorer-messenger": "^0.1.1",
    "uuid": "^9.0.1"
  }
}
