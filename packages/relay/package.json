{
  "name": "@coveo/relay",
  "version": "1.2.7",
  "description": "A library for sending analytics events using Coveo's Event protocol.",
  "type": "module",
  "files": [
    "lib/npm/*",
    "lib/docs/*"
  ],
  "types": "./lib/npm/relay.d.ts",
  "exports": {
    "types": "./lib/npm/relay.d.ts",
    "import": "./lib/npm/relay.mjs",
    "require": "./lib/npm/relay.cjs",
    "browser": "./lib/npm/relay.mjs",
    "default": "./lib/npm/relay.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coveo-platform/relay.git"
  },
  "keywords": [
    "Coveo",
    "analytics",
    "event",
    "Event Protocol"
  ],
  "author": "Coveo",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/coveo-platform/relay/issues"
  },
  "homepage": "https://github.com/coveo-platform/relay#readme",
  "scripts": {
    "build": "npm run clean && rollup --config ./config/rollup.config.mjs && npm run typedoc",
    "clean": "rimraf -rf ./lib",
    "lint": "eslint src/**",
    "lint:fix": "npm run lint -- --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "npm:tag": "node ./scripts/update-npm-tag.mjs",
    "typedoc": "typedoc"
  },
  "devDependencies": {
    "@octokit/rest": "^22.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-replace": "^6.0.0",
    "@rollup/plugin-terser": "^0.4.3",
    "@rollup/plugin-typescript": "^12.0.0",
    "@types/jest": "^29.5.3",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "rimraf": "6.0.1",
    "rollup": "^4.0.0",
    "ts-jest": "^29.1.1",
    "tsconfig": "workspace:*",
    "typedoc": "^0.28.0",
    "typescript": "^5.1.6"
  },
  "dependencies": {
    "@coveo/explorer-messenger": "^0.4.1",
    "uuid": "^11.0.0"
  }
}
