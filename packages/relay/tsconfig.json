{
  "extends": "tsconfig/base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM"],
    "target": "ES2022",
    "rootDir": "src",
    "types": ["vitest/globals"]
  },
  "include": ["src/**/*.ts"],
  "typedocOptions": {
    "entryPointStrategy": "expand",
    "json": "lib/docs/relay-docs.json",
    "entryPoints": ["src/relay.ts"],
    "includeVersion": true,
    "excludePrivate": true,
    "excludeNotDocumented": true,
    "treatWarningsAsErrors": true
  }
}
