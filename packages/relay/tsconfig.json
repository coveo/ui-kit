{
  "compilerOptions": {
    "composite": false,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "inlineSources": false,
    "isolatedModules": true,
    "skipLibCheck": true,
    "strict": true,
    "lib": ["ES2022", "DOM"],
    "module": "node16",
    "target": "ES2022",
    "moduleResolution": "node16",
    "rootDir": "src",
    "types": ["vitest/globals", "node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "src/**/*.test.ts", "src/__mocks__/**/*.ts"],
  "typedocOptions": {
    "entryPointStrategy": "expand",
    "json": "lib/docs/relay-docs.json",
    "entryPoints": ["src/relay.ts"],
    "includeVersion": true,
    "excludePrivate": true,
    "excludeNotDocumented": true,
    "treatWarningsAsErrors": true
  }
}
