{
  "extends": "tsconfig/base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM"],
    "target": "ES2022"
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "lib"],
  "typedocOptions": {
    "entryPointStrategy": "expand",
    "json": "relay-docs.json",
    "entryPoints": ["src/relay.ts"],
    "includeVersion": true,
    "excludePrivate": true,
    "excludeNotDocumented": true,
  }
}
