{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Node",
    "target": "es5",
    "rootDir": "./src",
    "declarationDir": "./dist/definitions",
    "declaration": true,
    "noImplicitAny": true,
    "removeComments": true,
    "sourceMap": true,
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true,
    "strict": true,
    "lib": ["es5", "dom", "scripthost", "es6"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.spec.ts"]
}
