{
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["build:storybook", "build:lit", "build:cdn"],
      "outputs": []
    },
    "build:locales": {
      "outputs": ["dist/lang/**", "src/assets/lang/**", "src/generated/**"]
    },
    "build:assets": {
      "outputs": ["dist/assets/**"]
    },
    "build:themes": {
      "outputs": ["dist/themes/**"]
    },
    "build:storybook": {
      "dependsOn": ["^build", "build:cem"],
      "outputs": ["./dist-storybook/**"]
    },
    "chromatic": {
      "dependsOn": ["build:storybook"],
      "outputs": [],
      "env": [
        "CHROMATIC_PROJECT_TOKEN",
        "CHROMATIC_SHA",
        "CHROMATIC_BRANCH",
        "CHROMATIC_SLUG"
      ]
    },
    "build:cem": {
      "outputs": ["./custom-elements.json"]
    },
    "build:lit": {
      "dependsOn": ["^build", "build:locales"],
      "outputs": ["dist/esm/**", "dist/cjs/**", "dist/types/**", "docs/**"]
    },
    "build:cdn": {
      "dependsOn": [
        "^build",
        "build:lit",
        "build:locales",
        "build:assets",
        "build:themes"
      ],
      "outputs": ["cdn/**"]
    },
    "test:lit": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:storybook": {
      "dependsOn": ["^build", "build"],
      "outputs": []
    },
    "dev": {
      "extends": false,
      "with": ["dev:storybook"],
      "cache": false,
      "persistent": true
    },
    "dev:storybook": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "web:dev": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },
    "web:cdn": {
      "dependsOn": ["build:cdn"],
      "cache": false,
      "persistent": true
    }
  }
}
