{
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["build:storybook", "build:lit", "build:cdn"],
      "outputs": []
    },
    "build:storybook": {
      "dependsOn": ["^build", "build:cem"],
      "outputs": ["./dist-storybook/**"]
    },
    "chromatic": {
      "dependsOn": ["build:storybook"],
      "outputs": [],
      "env": [
        "CHROMATIC_PROJECT_TOKEN",
        "CHROMATIC_SHA",
        "CHROMATIC_BRANCH",
        "CHROMATIC_SLUG"
      ]
    },
    "build:cem": {
      "outputs": ["./custom-elements.json"]
    },
    "build:lit": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        "docs/**",
        "src/generated/**",
        "src/assets/lang/**"
      ]
    },
    "build:cdn": {
      "dependsOn": ["^build"],
      "outputs": ["cdn/**"]
    },
    "test:lit": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:storybook": {
      "dependsOn": ["^build", "build"],
      "outputs": []
    },
    "dev": {
      "extends": false,
      "with": ["dev:storybook"],
      "cache": false,
      "persistent": true
    },
    "dev:storybook": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "web:dev": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },
    "web:cdn": {
      "dependsOn": ["build:cdn"],
      "cache": false,
      "persistent": true
    }
  }
}
