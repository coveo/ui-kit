{
  "name": "@coveo/atomic",
  "type": "module",
  "version": "3.52.1",
  "description": "A web-component library for building modern UIs interfacing with the Coveo platform",
  "homepage": "https://docs.coveo.com/en/atomic/latest/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coveo/ui-kit.git",
    "directory": "packages/atomic"
  },
  "main": "dist/cjs/index.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    "./loader": {
      "types": "./dist/types/loader.d.ts",
      "import": "./dist/atomic/components/loader.js",
      "require": "./dist/cjs/loader.cjs.js"
    },
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/atomic/components/index.js",
      "require": "./dist/cjs/index.cjs.js"
    },
    "./themes/*": {
      "import": "./dist/atomic/themes/*",
      "require": "./dist/atomic/themes/*"
    },
    "./assets/*": {
      "import": "./dist/atomic/assets/*",
      "require": "./dist/atomic/assets/*"
    },
    "./lang/*": {
      "import": "./dist/atomic/lang/*",
      "require": "./dist/atomic/lang/*"
    },
    "./components": {
      "types": "./dist/types/components/index.d.ts",
      "import": "./dist/atomic/components/components/index.js"
    },
    "./custom-elements-manifest": "./custom-elements.json"
  },
  "sideEffects": [
    "./dist/atomic/components/components/*/*/*.js",
    "./dist/esm/index.js",
    "./dist/esm/loader.js",
    "./dist/cjs/loader.cjs.js"
  ],
  "files": [
    "custom-elements.json",
    "dist/",
    "docs/",
    "licenses/"
  ],
  "scripts": {
    "clean": "node ../../utils/ci/rm-rf.mjs dist/* dist-storybook/* www/* docs/* playwright-report/*",
    "build:storybook": "storybook build -o dist-storybook --stats-json",
    "build:cem": "cem analyze",
    "build:stencil-lit": "node ./scripts/build.mjs --config=tsconfig.lit.json",
    "build:cdn": "rollup -c rollup.config.js",
    "build:angular": "npx turbo gen:lit --filter=@coveo/atomic-angular-builder",
    "build:react": "npx turbo gen:lit --filter=@coveo/atomic-react",
    "build:locales": "node ./scripts/create-generated-folder.mjs && node ./scripts/split-locales.mjs && node ./scripts/copy-dayjs-locales.mjs",
    "build:copy-assets": "node ./scripts/copy-assets.mjs",
    "build:list-assets": "node ./scripts/list-assets.mjs",
    "dev": "node ./scripts/dev.mjs",
    "web:dev": "npx vite serve dev",
    "web:cdn": "node ./scripts/start-cdn.mjs",
    "test": "pnpm run test:lit",
    "test:stencil": "stencil test --spec -- src/utils/initialization-utils.spec.ts",
    "test:lit": "vitest run --project=atomic-default",
    "test:watch": "vitest --project=atomic-default",
    "test:storybook": "vitest run --project=storybook",
    "generate-component": "node ./scripts/generate-component.mjs",
    "release:phase3": "pnpm --filter @coveo/ci npm-publish",
    "release:phase1": "pnpm --filter @coveo/ci bump",
    "promote:npm:latest": "pnpm --filter @coveo/ci promote-npm-prod",
    "validate:definitions": "tsc --noEmit --esModuleInterop --skipLibCheck ./dist/types/components.d.ts",
    "chromatic": "chromatic -d=dist-storybook",
    "validate:light-dom-styles": "node ./scripts/check-light-dom-host-selectors.mjs",
    "validate:no-new-light-dom": "node ./scripts/check-no-new-light-dom-components.mjs"
  },
  "dependencies": {
    "@coveo/atomic-legacy": "workspace:*",
    "@coveo/relay-event-types": "catalog:",
    "@lit/context": "1.1.6",
    "@open-wc/lit-helpers": "0.7.0",
    "@popperjs/core": "2.11.8",
    "@salesforce-ux/design-system": "2.27.2",
    "@stencil/core": "catalog:",
    "cssnano": "7.1.1",
    "dayjs": "catalog:",
    "dompurify": "3.2.6",
    "escape-html": "1.0.3",
    "i18next": "25.3.2",
    "i18next-http-backend": "3.0.2",
    "lit": "3.3.1",
    "marked": "12.0.2"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "0.10.4",
    "@playwright/test": "catalog:",
    "@rollup/plugin-commonjs": "28.0.6",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-node-resolve": "16.0.1",
    "@rollup/plugin-replace": "catalog:",
    "@storybook/addon-a11y": "10.0.8",
    "@storybook/addon-docs": "10.0.8",
    "@storybook/addon-mcp": "0.1.3",
    "@storybook/addon-vitest": "10.0.8",
    "@storybook/icons": "2.0.1",
    "@storybook/web-components-vite": "10.0.8",
    "@tailwindcss/postcss": "4.1.13",
    "@tailwindcss/vite": "4.1.13",
    "@types/escape-html": "1.0.4",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@wc-toolkit/storybook-helpers": "10.0.0",
    "chromatic": "13.3.4",
    "handlebars": "4.7.8",
    "lit-html": "3.3.1",
    "msw": "2.11.4",
    "msw-storybook-addon": "2.0.5",
    "playwright": "catalog:",
    "postcss": "8.5.6",
    "postcss-load-config": "6.0.1",
    "prettier": "catalog:",
    "puppeteer": "catalog:",
    "react": "catalog:",
    "remark-gfm": "4.0.1",
    "rollup": "4.46.2",
    "rollup-plugin-copy": "3.5.0",
    "shadow-dom-testing-library": "1.12.0",
    "storybook": "10.0.8",
    "tailwindcss": "4.1.13",
    "ts-dedent": "2.2.0",
    "ts-lit-plugin": "2.0.2",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "wait-on": "8.0.4"
  },
  "peerDependencies": {
    "@coveo/bueno": "workspace:*",
    "@coveo/headless": "workspace:*",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "license": "Apache-2.0",
  "engines": {
    "node": "^20.9.0 || ^22.11.0 || ^24.11.0"
  },
  "msw": {
    "workerDirectory": [
      ".storybook/public"
    ]
  }
}
