{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "ES2022",
    "target": "ES2021",
    "moduleResolution": "bundler",
    "lib": ["dom", "ES2024", "DOM.Iterable"],
    "declaration": true,
    "resolveJsonModule": true,
    "declarationDir": "dist/types",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "outDir": "dist/esm",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "files": [
    "src/index.ts",
    "src/loader.ts",
    "src/components/index.ts",
    "src/icons.d.ts"
  ]
}
