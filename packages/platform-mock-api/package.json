{
  "name": "@coveo/platform-mock-api",
  "version": "0.0.0",
  "private": true,
  "description": "Coveo Platform API mock layer for testing (search, commerce, insight, recommendations)",
  "files": [
    "dist/"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noCheck",
    "clean": "node ../../utils/ci/rm-rf.mjs dist"
  },
  "devDependencies": {
    "@ag-ui/client": "catalog:",
    "@coveo/headless": "workspace:*",
    "msw": "catalog:",
    "natural-orderby": "5.0.0",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "msw": "catalog:"
  }
}
