{
  "name": "@coveo/create-atomic-component",
  "version": "1.5.15",
  "description": "Initialize a Coveo Atomic Component",
  "keywords": [
    "atomic",
    "cli",
    "coveo"
  ],
  "license": "Apache-2.0",
  "author": "Coveo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coveo/ui-kit.git",
    "directory": "packages/create-atomic-component"
  },
  "bin": "index.js",
  "files": [
    "index.js",
    "template/src/components/sample-component/src/**/*",
    "template/src/components/sample-component/.gitignore",
    "template/src/components/sample-component/package.json",
    "template/src/components/sample-component/stencil.config.ts",
    "template/src/components/sample-component/tsconfig.json",
    "template/.gitignore"
  ],
  "type": "module",
  "main": "index.js",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "publish:bump": "pnpm --filter @coveo/ci bump",
    "release:phase1": "pnpm run publish:bump",
    "npm:publish": "pnpm --filter @coveo/ci npm-publish"
  },
  "dependencies": {
    "@coveo/create-atomic-component-project": "1.5.11"
  },
  "engines": {
    "node": "^20.9.0 || ^22.11.0 || ^24.11.0"
  }
}
