{
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["build:assets", "build:types", "build:bundles"],
      "outputs": []
    },
    "build:bundles": {
      "dependsOn": ["gen:lit", "@coveo/atomic#build:lit"],
      "outputs": ["./dist/esm/**", "./dist/cjs/**"]
    },
    "build:types": {
      "dependsOn": ["@coveo/atomic#build:lit"],
      "outputs": ["./dist/types/**"]
    },
    "build:assets": {
      "dependsOn": [
        "@coveo/atomic#build:locales",
        "@coveo/atomic#build:assets"
      ],
      "outputs": ["./dist/assets/**", "./dist/lang/**"]
    },
    "gen:lit": {
      "dependsOn": ["@coveo/atomic#build:cem"],
      "outputs": [
        "src/components/search/components.ts",
        "src/components/commerce/components.ts"
      ]
    },
    "release:phase1": {
      "dependsOn": ["^release:phase1", "@coveo/headless#release:phase1"],
      "outputs": []
    }
  }
}
