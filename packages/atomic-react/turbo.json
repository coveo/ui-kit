{
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["build:assets", "build:types", "build:bundles"],
      "outputs": []
    },
    "build:bundles": {
      "dependsOn": ["gen:lit"],
      "outputs": ["./dist/esm", "./dist/cjs"]
    },
    "build:types": {
      "dependsOn": ["gen:lit"],
      "outputs": ["./dist/types"]
    },
    "build:assets": {
      "dependsOn": ["@coveo/atomic#build:stencil-lit"],
      "outputs": ["./dist/assets", "./dist/lang"]
    },
    "gen:lit": {
      "dependsOn": ["@coveo/atomic#build:cem"],
      "outputs": [
        "src/components/search/component.ts",
        "src/components/commerce/component.ts"
      ]
    },
    "release:phase1": {
      "dependsOn": ["^release:phase1", "@coveo/headless#release:phase1"],
      "outputs": []
    }
  }
}
