{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  enabled: true,
  extends: ['github>coveo/renovate-presets', 'helpers:pinGitHubActionDigests'],
  labels: ['dependencies'],
  dependencyDashboard: true,
  packageRules: [
    {
      groupName: 'all dependencies',
      groupSlug: 'all',
      matchPackageNames: ['*'],
    },
    {
      groupName: 'tailwind',
      groupSlug: 'tailwind',
      rangeStrategy: 'replace',
      description: 'Isolate tailwind for breaking changes',
      matchPackageNames: [
        'tailwindcss',
        '@tailwindcss/postcss',
        '@tailwindcss/vite',
      ],
    },
    {
      groupName: 'Angular',
      groupSlug: 'angular',
      rangeStrategy: 'replace',
      allowedVersions: '18.x',
      matchPackageNames: [
        '/^@angular/*/',
        '/^@angular-devkit/*/',
        '/ng-packagr/',
      ],
    },
    {
      groupName: 'Redux',
      groupSlug: 'Redux',
      rangeStrategy: 'replace',
      matchPackageNames: ['/^redux-*/', '/^@redux/*/'],
    },
    {
      groupName: 'Stencil',
      groupSlug: 'stencil',
      rangeStrategy: 'replace',
      matchPackageNames: ['/^@stencil/*/'],
    },
    {
      groupName: 'LWC Compiler',
      groupSlug: 'lwc-compiler',
      rangeStrategy: 'replace',
      matchPackageNames: ['/^@lwc/compiler$/'],
    },
    {
      matchFileNames: [
        'packages/atomic/package.json',
        'packages/create-atomic-component/template/src/components/sample-component/package.json',
        'packages/create-atomic-component-project/template/package.json',
      ],
      groupSlug: 'atomic-jest',
      rangeStrategy: 'replace',
      allowedVersions: '27.x',
      description: 'Stencil do not support Jest >27 https://stenciljs.com/docs/support-policy#testing-libraries',
      matchPackageNames: [
        '/^jest$/',
        '/^jest-cli$/',
        '/@types/jest/',
        '/jest-environment-node/',
      ],
    },
    {
      groupName: 'marked',
      groupSlug: 'marked',
      rangeStrategy: 'replace',
      description: 'Isolate marked',
      matchPackageNames: ['marked'],
    },
    {
      groupName: 'relay',
      groupSlug: 'relay',
      rangeStrategy: 'replace',
      description: 'Isolate relay since it is causing issues with stencil projetcs',
      matchPackageNames: ['@coveo/relay'],
    },
    {
      groupName: 'knip',
      groupSlug: 'knip',
      rangeStrategy: 'replace',
      description: 'Isolate knip since updates can break CI',
      matchPackageNames: ['knip'],
    },
    {
      groupName: 'publint',
      groupSlug: 'publint',
      rangeStrategy: 'replace',
      description: 'Isolate publint since updates can break CI',
      matchPackageNames: ['publint'],
    },
    {
      groupName: 'Quantic-only dependencies',
      groupSlug: 'quantic-deps',
      rangeStrategy: 'replace',
      description: 'Group all dependencies only used by the Quantic package',
      matchPackageNames: [
        '@babel/cli',
        '@babel/plugin-transform-async-to-generator',
        '@octokit/graphql',
        '@octokit/graphql-schema',
        '@salesforce/eslint-config-lwc',
        '@salesforce/sfdx-lwc-jest',
        '@types/wait-on',
        '@typescript-eslint/parser',
        'dotenv',
        'eslint',
        'eslint-config-prettier',
        'jest-junit',
        'jsdoc',
        'jsdoc-tsimport-plugin',
        'prettier-plugin-apex',
        'ts-node',
        'xml2js',
      ],
    },
  ],
  lockFileMaintenance: {
    enabled: true,
  },
  rangeStrategy: 'auto',
  commitMessageSuffix: 'J:KIT-282',
  vulnerabilityAlerts: {
    enabled: false,
  },
  postUpdateOptions: ['pnpmDedupe'],
  ignoreDeps: [
    'fix-esm-import-path',
    // Ignore cypress since it is getting removed.
    'cypress',
    'cypress-split',
    'cypress-repeat',
    'cypress-real-events',
    'cypress-web-vitals',
    'cypress-axe',
    // Ignore marked to not have a floating PR.
    'marked',
    // Ignore stencil since it is getting removed.
    '@stencil/core',
    '@stencil/angular-output-target',
    '@stencil/react-output-target',
    '@stencil-community/postcss',
    // Ignore gts since it is getting removed.
    'gts',
    // Ignore storybook since it breaks because of stencil. We will update after migration.
    '@storybook/addon-a11y',
    '@storybook/web-components-vite',
    'storybook',
    '@storybook/addon-docs',
    '@storybook/addon-mcp',
    '@storybook/addon-vitest',
    'msw-storybook-addon',
    // Problems with angular. Just ignore it.
    'zone.js',
  ],
}
