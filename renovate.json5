{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  enabled: true,
  extends: ['github>coveo/renovate-presets', 'helpers:pinGitHubActionDigests'],
  labels: ['dependencies'],
  dependencyDashboard: true,
  packageRules: [
    {
      groupName: 'all production dependencies',
      groupSlug: 'prod',
      matchPackageNames: ['*'],
      matchDepTypes: ['dependencies'],
    },
    {
      groupName: 'all dev dependencies',
      groupSlug: 'dev',
      matchPackageNames: ['*'],
      matchDepTypes: [
        'devDependencies',
        'peerDependencies',
        'optionalDependencies',
      ],
    },
    {
      groupName: 'Changesets',
      groupSlug: 'changesets',
      description: 'Isolate @changesets/* since we rely on experimental options that may change in a patch update',
      matchPackageNames: ['@changesets/*'],
    },
    {
      groupName: 'wc-toolkit storybook-helpers',
      groupSlug: 'wc-toolkit-storybook-helpers',
      rangeStrategy: 'replace',
      description: 'Isolate @wc-toolkit/storybook-helpers since it has a pnpm patch that needs updating on every bump',
      matchPackageNames: ['@wc-toolkit/storybook-helpers'],
    },
    {
      groupName: 'Quantic-only dependencies',
      groupSlug: 'quantic-deps',
      rangeStrategy: 'replace',
      description: 'Group all dependencies only used by the Quantic package',
      matchPackageNames: [
        '@babel/cli',
        '@babel/plugin-transform-async-to-generator',
        '@octokit/graphql',
        '@octokit/graphql-schema',
        '@salesforce/eslint-config-lwc',
        '@salesforce/sfdx-lwc-jest',
        '@types/wait-on',
        '@typescript-eslint/parser',
        'dotenv',
        'eslint',
        'eslint-config-prettier',
        'jest-junit',
        'jsdoc',
        'jsdoc-tsimport-plugin',
        'prettier-plugin-apex',
        'ts-node',
        'xml2js',
        '/^@lwc/compiler$/',
      ],
    },
  ],
  lockFileMaintenance: {
    enabled: true,
  },
  rangeStrategy: 'auto',
  commitMessageSuffix: 'J:KIT-282',
  vulnerabilityAlerts: {
    enabled: false,
  },
  postUpdateOptions: ['pnpmDedupe'],
  ignoreDeps: [
    'fix-esm-import-path',
    // Ignore marked to not have a floating PR.
    'marked',
    // Ignore stencil since it is getting removed.
    '@stencil/core',
    '@stencil/angular-output-target',
    '@stencil/react-output-target',
    '@stencil-community/postcss',
    // Ignore gts since it is getting removed.
    'gts',
    // Ignore jest since Atomic moved to Vitest and templates use catalog.
    'jest',
    'jest-cli',
    '@types/jest',
    'jest-environment-node',
    'jest-environment-jsdom',
    // Problems with angular. Just ignore it.
    'zone.js',
  ],
}
