{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "schedule": "before 9am on Tuesday",
  "extends": [
    "github>coveo-platform/renovate-presets",
    "group:allNonMajor",
    "github>coveo-platform/renovate-presets//auto-merge.json"
  ],
  "packageRules": [
    {
      // Completely disable auto merge for major versions of any dependency
      "matchUpdateType": ["major"],
      "automerge": false
    }
  ]
  "prHeader": "UA-5791"
}
